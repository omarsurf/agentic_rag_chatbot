# =============================================================================
# Agentic RAG GRI/FAR - Configuration Environment
# =============================================================================
# Copier ce fichier vers .env et remplir les valeurs

# === Hugging Face API ===
# Obtenir une clé sur https://huggingface.co/settings/tokens
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Modèles Hugging Face ===
# Modèle pour le routing des queries (léger, rapide)
HF_ROUTER_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Modèle principal pour l'orchestration (plus capable)
HF_ORCHESTRATOR_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# Modèle pour la génération de réponses
HF_GENERATION_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# Modèle pour l'évaluation
HF_EVAL_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# === Alternatives recommandées ===
# Pour le français : croissantllm/CroissantLLMChat-v0.1
# Open source : meta-llama/Meta-Llama-3-8B-Instruct

# === Vector Store (Qdrant) ===
QDRANT_URL=localhost
QDRANT_PORT=6333
# Qdrant
# Laisser vide en local, définir une valeur forte en production si Qdrant est exposé.
QDRANT_API_KEY=

# === Collections Qdrant ===
QDRANT_COLLECTION_MAIN=gri_main
QDRANT_COLLECTION_GLOSSARY=gri_glossary

# === Embeddings ===
# Modèle multilingue FR+EN (NON NÉGOCIABLE)
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIMENSION=768

# === Reranker ===
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# === API Configuration ===
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# === API Security ===
# Auth simple par Bearer token. Désactiver seulement en local strict.
API_AUTH_ENABLED=false
API_BEARER_TOKEN=

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json  # json | console

# === Paths ===
DATA_DIR=./data
REPORTS_DIR=./reports
CONFIG_PATH=./configs/config.yaml

# === Agent Configuration ===
AGENT_MAX_ITERATIONS=5
AGENT_TIMEOUT_SECONDS=120

# === Retrieval Configuration ===
RRF_ALPHA=0.6
RRF_K=60
DEFAULT_N_RESULTS=5
RERANK_TOP_K=10

# === Generation Configuration ===
GENERATION_MAX_TOKENS=2048
DEFINITION_TEMPERATURE=0.0
GENERAL_TEMPERATURE=0.1

# === Evaluation ===
EVAL_FAITHFULNESS_THRESHOLD=0.85
EVAL_ANSWER_RELEVANCE_THRESHOLD=0.80
EVAL_CONTEXT_RECALL_THRESHOLD=0.75
EVAL_TERM_ACCURACY_THRESHOLD=0.95
EVAL_LATENCY_P95_MS=8000
